APP_NAME="DMS Backend"
ENVIRONMENT=production
INFERENCE_RUNNER=bamti-torch
MODEL_PATH=/models/final_model.pth
MODEL_DEVICE=cuda
MODEL_INPUT_SIZE=224
MODEL_SCORE_ACTIVATION=softmax
OMP_NUM_THREADS=2
MKL_NUM_THREADS=2
TORCH_NUM_THREADS=2
TORCH_COMPILE_BACKEND=inductor
TORCH_COMPILE_MODE=reduce-overhead
TELEMETRY_RUNS_DIR=/app/telemetry_runs
MAX_FRAME_BYTES=1048576
DATABASE_URL=mysql+aiomysql://dms_user:dms_password@mysql:3306/dms

MYSQL_DATABASE=dms
MYSQL_USER=dms_user
MYSQL_PASSWORD=dms_password
MYSQL_ROOT_PASSWORD=dms_root_password

NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility
PUBLIC_DOMAIN=localhost
